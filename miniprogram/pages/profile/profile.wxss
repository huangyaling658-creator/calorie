.streak-card{display:flex;align-items:center;gap:24rpx;background:linear-gradient(135deg,#FF8A00,#CC6E00);border-radius:24rpx;padding:32rpx;box-shadow:0 8rpx 24rpx rgba(204,110,0,0.3);margin-bottom:24rpx;}
.streak-fire{font-size:64rpx;}.streak-num{font-size:56rpx;font-weight:700;color:#FFF;display:block;}.streak-label{font-size:26rpx;color:rgba(255,255,255,0.8);display:block;}
.report-section{margin-top:4rpx;}
.report-tabs{display:flex;background:#FFF;border-radius:20rpx;padding:6rpx;margin-bottom:24rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.04);}
.report-tab{flex:1;text-align:center;padding:18rpx 0;font-size:28rpx;font-weight:600;color:#8E8E93;border-radius:16rpx;}
.report-tab.active{background:#FF8A00;color:#FFF;box-shadow:0 4rpx 12rpx rgba(255,138,0,0.3);}

/* 周视图 - 朋友圈风格 */
.week-report{}
.week-card{background:#FFF;border-radius:24rpx;padding:24rpx 28rpx;margin-bottom:16rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.04);}
.wc-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx;}
.wc-date{display:flex;align-items:baseline;gap:10rpx;}
.wc-weekday{font-size:24rpx;color:#8E8E93;font-weight:500;}
.wc-daynum{font-size:34rpx;font-weight:700;color:#333;}
.wc-cal{font-size:24rpx;color:#FF8A00;font-weight:600;background:#FFF7ED;padding:6rpx 16rpx;border-radius:20rpx;}

/* 图片九宫格 */
.wc-photo-grid{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:16rpx;}
.wc-photo{border-radius:12rpx;object-fit:cover;}
.wc-grid-1 .wc-photo{width:320rpx;height:320rpx;}
.wc-grid-2 .wc-photo{width:calc(50% - 4rpx);height:240rpx;}
.wc-grid-3 .wc-photo{width:calc(33.33% - 6rpx);height:200rpx;}
.wc-grid-multi .wc-photo{width:calc(33.33% - 6rpx);height:200rpx;}

/* 食物标签 */
.wc-chips{display:flex;flex-wrap:wrap;gap:12rpx;margin-bottom:12rpx;}
.wc-chip{display:inline-flex;align-items:center;gap:8rpx;padding:8rpx 18rpx;background:#FFF7ED;border-radius:28rpx;}
.wc-chip-img{width:36rpx;height:36rpx;border-radius:50%;flex-shrink:0;}
.wc-chip-icon{font-size:26rpx;}
.wc-chip-name{font-size:22rpx;color:#5C4813;max-width:140rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

/* 展开更多 */
.wc-expand{text-align:center;padding:8rpx 0;}
.wc-expand-text{font-size:24rpx;color:#FF8A00;font-weight:500;}

/* 空状态 */
.wc-empty{padding:12rpx 0;}.wc-empty-text{font-size:22rpx;color:#C7C7CC;}

/* 月视图 */
.month-report{background:#FFF;border-radius:24rpx;padding:24rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.04);}
.month-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:20rpx;}
.month-arrow{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:40rpx;color:#FF8A00;font-weight:700;}
.month-title{font-size:30rpx;font-weight:700;}
.month-header{display:flex;margin-bottom:12rpx;}.mh-cell{flex:1;text-align:center;font-size:22rpx;color:#8E8E93;font-weight:500;}
.month-grid{display:flex;flex-wrap:wrap;}
.month-cell{width:calc(100% / 7);display:flex;flex-direction:column;align-items:center;padding:8rpx 0;min-height:100rpx;box-sizing:border-box;}
.month-cell.empty{min-height:0;}
.month-cell.today .mc-num{background:#FF8A00;color:#FFF;border-radius:50%;width:40rpx;height:40rpx;display:flex;align-items:center;justify-content:center;}
.mc-num{font-size:24rpx;font-weight:600;color:#333;margin-bottom:4rpx;}
.mc-thumb{width:40rpx;height:40rpx;border-radius:8rpx;margin-top:2rpx;}
.mc-icons{display:flex;gap:2rpx;flex-wrap:wrap;justify-content:center;max-width:90rpx;}.mc-icon{font-size:20rpx;}
.mc-dot{width:10rpx;height:10rpx;border-radius:50%;background:#FF8A00;margin-top:4rpx;}
