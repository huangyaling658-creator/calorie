page{background:#FFFBF5;} .page-bg{min-height:100vh;background:#FFFBF5;}
.nav-bar{position:fixed;top:0;left:0;right:0;z-index:100;background:#FFFBF5;}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:88rpx;padding:0 24rpx;}
.nav-back{padding:10rpx;} .nav-back-arrow{color:#FF8A00;font-size:44rpx;font-weight:500;}
.nav-title{font-size:34rpx;font-weight:600;} .nav-placeholder{width:64rpx;}
.content-area{padding:24rpx 28rpx 60rpx;}

.nav-arrow{position:fixed;top:50%;transform:translateY(-50%);z-index:50;width:72rpx;height:120rpx;display:flex;align-items:center;justify-content:center;background:rgba(255,138,0,0.9);box-shadow:0 4rpx 20rpx rgba(255,107,53,0.3);}
.nav-arrow-left{left:0;border-radius:0 24rpx 24rpx 0;}
.nav-arrow-right{right:0;border-radius:24rpx 0 0 24rpx;}
.arrow-icon{color:#fff;font-size:48rpx;font-weight:700;}
.arrow-dis{opacity:0.2;pointer-events:none;}

.food-indicator{display:flex;align-items:center;justify-content:center;gap:12rpx;margin-bottom:8rpx;}
.indicator-dot{width:14rpx;height:14rpx;border-radius:50%;background:#E0D6C8;transition:all 0.3s;}
.dot-active{width:32rpx;border-radius:7rpx;background:#FF8A00;}

.food-counter{text-align:center;margin-bottom:12rpx;}
.counter-text{font-size:24rpx;color:#8E8E93;background:#FFF7ED;padding:4rpx 20rpx;border-radius:20rpx;}

.food-icon-big{width:200rpx;height:200rpx;border-radius:24rpx;background:#FFF7ED;margin:20rpx auto 16rpx;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.food-img-big{width:200rpx;height:200rpx;border-radius:24rpx;}
.icon-emoji{font-size:72rpx;}
.food-name-big{display:block;text-align:center;font-size:38rpx;font-weight:700;margin-bottom:8rpx;}
.food-meta{display:flex;align-items:center;justify-content:center;gap:12rpx;margin-bottom:28rpx;flex-wrap:wrap;}
.food-type-badge{background:#FF8A00;color:#fff;font-size:22rpx;padding:4rpx 16rpx;border-radius:20rpx;}
.food-portion{font-size:24rpx;color:#8E8E93;} .food-time-badge{font-size:22rpx;color:#8E8E93;}

.section-label{font-size:28rpx;font-weight:600;margin:24rpx 0 14rpx;padding-left:4rpx;}
.nutri-grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx;margin-bottom:14rpx;}
.nutri-item{border-radius:20rpx;padding:24rpx 20rpx;display:flex;flex-direction:column;align-items:center;}
.nutri-val{font-size:44rpx;font-weight:700;line-height:1.2;}
.nutri-unit{font-size:20rpx;color:rgba(0,0,0,0.5);margin-top:2rpx;}
.nutri-label{font-size:22rpx;color:rgba(0,0,0,0.6);margin-top:6rpx;}
.cal-bg{background:#FFF3E8;} .cal-bg .nutri-val{color:#FF6B35;}
.pro-bg{background:#FFF0F0;} .pro-bg .nutri-val{color:#FF5252;}
.fat-bg{background:#F0FFF4;} .fat-bg .nutri-val{color:#4CAF50;}
.carb-bg{background:#F0F4FF;} .carb-bg .nutri-val{color:#2196F3;}

.nutri-row-extra{display:flex;gap:14rpx;margin-bottom:8rpx;}
.nutri-mini{flex:1;display:flex;align-items:center;background:#FAFAF5;border-radius:16rpx;padding:16rpx 20rpx;gap:8rpx;}
.nm-icon{font-size:28rpx;} .nm-label{font-size:22rpx;color:#8E8E93;flex:1;}
.nm-val{font-size:24rpx;font-weight:600;color:#5C4813;}
.fiber-bg{background:#F0FFF0;} .sodium-bg{background:#EEF4FF;}

.summary-tag{background:#FFF7ED;border-left:6rpx solid #FF8A00;padding:16rpx 20rpx;border-radius:0 16rpx 16rpx 0;font-size:26rpx;color:#5C4813;margin-bottom:12rpx;line-height:1.6;}
.analysis-card{background:#FFF;border-radius:20rpx;padding:24rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.04);margin-bottom:4rpx;}
.analysis-text{font-size:24rpx;color:#5C4813;line-height:1.8;}

.compare-list{background:#FFF;border-radius:20rpx;padding:8rpx 20rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.04);}
.compare-item{display:flex;align-items:center;padding:18rpx 0;border-bottom:1rpx solid #F5F0E8;}
.compare-item:last-child{border-bottom:none;}
.comp-icon{font-size:32rpx;margin-right:16rpx;}
.comp-text{font-size:26rpx;color:#5C4813;flex:1;}

.add-btn-wrap{padding:40rpx 0 60rpx;position:sticky;bottom:0;background:#FFFBF5;}
.add-btn{background:linear-gradient(135deg,#FF8A00,#FF6B35);border-radius:48rpx;padding:28rpx 0;text-align:center;box-shadow:0 8rpx 24rpx rgba(255,107,53,0.3);transition:all 0.3s;}
.add-btn-done{background:linear-gradient(135deg,#A0D468,#8CC152);box-shadow:0 8rpx 24rpx rgba(140,193,82,0.3);pointer-events:none;}
.add-btn-text{color:#fff;font-size:32rpx;font-weight:600;letter-spacing:2rpx;}
