<view class="page-container">
  <scroll-view class="calendar-bar" scroll-x="true" scroll-into-view="{{scrollToDay}}" enhanced show-scrollbar="{{false}}">
    <view class="calendar-scroll">
      <view wx:for="{{calendarDays}}" wx:key="date" id="day-{{item.date}}"
        class="cal-day {{item.isToday?'today':''}} {{item.isSelected?'selected':''}} {{item.hasData?'has-data':''}}"
        bindtap="onSelectDay" data-date="{{item.date}}">
        <text class="cal-day-name">周{{item.dayName}}</text>
        <text class="cal-day-num">{{item.dayNum}}</text>
        <view class="cal-day-dot"></view>
      </view>
    </view>
  </scroll-view>
  <view class="tip-card">
    <text class="tip-badge">💡 减肥妙招</text>
    <text class="tip-text">{{dailyTip}}</text>
  </view>
  <view class="input-card">
    <text class="card-title">AI识别热量</text>
    <view class="textarea-wrap">
      <textarea class="food-textarea" placeholder="例如：一个汉堡和一杯可乐" value="{{foodInput}}" bindinput="onFoodInput" maxlength="500" adjust-position="{{true}}"/>
      <view wx:if="{{foodInput.length}}" class="clear-btn" catchtap="onClearInput">×</view>
    </view>
    <view class="action-row">
      <view class="mic-btn {{recording?'mic-recording':''}}" catchtap="onVoiceInput">
        <view wx:if="{{recording}}" class="mic-wave">
          <view class="mw-bar"></view><view class="mw-bar"></view><view class="mw-bar"></view>
          <view class="mw-bar"></view><view class="mw-bar"></view>
        </view>
        <view wx:else class="i-mic"><view class="i-mic-head"></view><view class="i-mic-body"></view><view class="i-mic-base"></view></view>
      </view>
      <text wx:if="{{recording}}" class="rec-hint">{{voiceText}}</text>
      <view style="flex:1"></view>
      <view class="act-btn" catchtap="onCamera">
        <view class="i-cam"><view class="i-cam-top"></view><view class="i-cam-body"><view class="i-cam-lens"></view></view></view>
      </view>
      <view class="act-btn" catchtap="onAlbum">
        <view class="i-alb"><view class="i-alb-frame"><view class="i-alb-mt"></view><view class="i-alb-sun"></view></view></view>
      </view>
    </view>
    <view wx:if="{{capturedImages.length}}" class="photo-grid">
      <view wx:for="{{capturedImages}}" wx:key="*this" class="photo-row">
        <image class="photo-thumb" src="{{item}}" mode="aspectFill"/>
        <view class="photo-remove" catchtap="onRemoveImage" data-index="{{index}}">×</view>
      </view>
    </view>
    <view wx:if="{{aiLoading}}" class="ai-loading-bar"><view class="ai-spin"></view><text class="ai-lt">AI 识别中...</text></view>
    <view class="ai-btn" bindtap="onAIRecognize"><text class="ai-btn-text">✨ AI 智能识别</text></view>
  </view>
  <view class="section-header">
    <text class="sh-title">今日摄入</text>
  </view>
  <view class="card summary-card">
    <view class="summary-left">
      <view class="summary-number"><text class="summary-value">{{totalCal}}</text><text class="summary-unit"> kcal</text></view>
    </view>
    <view class="ring-container">
      <canvas canvas-id="calRing" class="ring-canvas"></canvas>
      <view class="ring-icon-wrap"><text class="ring-icon-text">🔥</text></view>
    </view>
  </view>
  <view class="nutrient-row">
    <view class="nutrient-card"><text class="n-e">🥩</text><text class="n-l">蛋白质</text><text class="n-v">{{nutrientP}}g</text></view>
    <view class="nutrient-card"><text class="n-e">🌾</text><text class="n-l">碳水</text><text class="n-v">{{nutrientC}}g</text></view>
    <view class="nutrient-card"><text class="n-e">🥑</text><text class="n-l">脂肪</text><text class="n-v">{{nutrientF}}g</text></view>
  </view>
  <view class="section-header">
    <text class="sh-title">饮食清单</text>
  </view>
  <view class="card food-list-card" wx:if="{{displayFoods.length}}">
    <view wx:for="{{displayFoods}}" wx:key="id" class="food-entry" bindtap="onFoodDetail" data-id="{{item.id}}">
      <view class="food-entry-row">
        <view class="food-icon-wrap">
          <image wx:if="{{item.imageUrl}}" class="food-item-img" src="{{item.imageUrl}}" mode="aspectFill"/>
          <text wx:else class="food-item-icon">{{item.icon}}</text>
        </view>
        <view class="food-item-info">
          <text class="food-item-name">{{item.name}}</text>
          <text class="food-item-time">{{item.timeStr}}</text>
        </view>
        <text class="food-item-cal">{{item.cal}} kcal</text>
        <view class="food-item-del" catchtap="onDeleteFood" data-id="{{item.id}}">×</view>
      </view>
    </view>
    <view wx:if="{{allFoods.length > 3 && !showAllFoods}}" class="show-more" bindtap="onToggleShowAll">
      <text class="show-more-text">显示更多 ></text>
    </view>
  </view>
  <view style="height:180rpx;"></view>
</view>
