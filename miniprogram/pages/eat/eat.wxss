.calendar-bar{margin:12rpx 0 20rpx;white-space:nowrap;}
.calendar-scroll{display:flex;gap:10rpx;padding:8rpx 0;}
.cal-day{display:inline-flex;flex-direction:column;align-items:center;width:96rpx;padding:14rpx 8rpx 16rpx;border-radius:20rpx;background:#FFF;flex-shrink:0;}
.cal-day-name{font-size:22rpx;color:#8E8E93;font-weight:500;}
.cal-day-num{font-size:34rpx;font-weight:600;margin-top:6rpx;}
.cal-day-dot{width:10rpx;height:10rpx;border-radius:50%;margin-top:6rpx;background:transparent;}
.cal-day.has-data .cal-day-dot{background:#FF8A00;}
.cal-day.today{background:#FF8A00;color:#FFF;box-shadow:0 4rpx 16rpx rgba(255,138,0,0.35);}
.cal-day.today .cal-day-name{color:rgba(255,255,255,0.8);}
.cal-day.selected:not(.today){background:#FFD4A8;color:#CC6E00;}
.tip-card{background:linear-gradient(135deg,#FFF7ED,#FFFBEB);border-radius:24rpx;padding:24rpx 28rpx;margin-bottom:20rpx;border:2rpx solid #FEECC8;}
.tip-badge{font-size:24rpx;font-weight:600;color:#CC6E00;display:block;margin-bottom:8rpx;}
.tip-text{font-size:26rpx;line-height:1.6;color:#5C4813;}
.summary-card{display:flex;align-items:center;justify-content:space-between;}
.summary-number{margin-top:4rpx;}
.summary-value{font-size:80rpx;font-weight:700;letter-spacing:-4rpx;line-height:1;}
.summary-unit{font-size:28rpx;color:#8E8E93;}
.ring-container{width:160rpx;height:160rpx;position:relative;}
.ring-canvas{width:160rpx;height:160rpx;}
.ring-icon-wrap{position:absolute;top:-14rpx;left:-8rpx;width:160rpx;height:160rpx;pointer-events:none;display:flex;align-items:center;justify-content:center;box-sizing:border-box;}
.ring-icon-text{font-size:40rpx;line-height:160rpx;width:160rpx;text-align:center;height:160rpx;}
.nutrient-row{display:flex;gap:16rpx;margin-bottom:28rpx;}
.nutrient-card{flex:1;background:#FFF;border-radius:24rpx;padding:24rpx 16rpx;text-align:center;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.04);display:flex;flex-direction:column;align-items:center;gap:6rpx;}
.n-e{font-size:40rpx;} .n-l{font-size:22rpx;color:#8E8E93;} .n-v{font-size:30rpx;font-weight:700;color:#FF8A00;}
.section-title{font-size:32rpx;font-weight:700;margin-bottom:20rpx;padding:0 8rpx;}
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx;padding:0 8rpx;}
.sh-title{font-size:32rpx;font-weight:700;}
.center-add-area{display:flex;flex-direction:column;align-items:center;padding:32rpx 0 40rpx;}
.center-add-btn{width:120rpx;height:120rpx;border-radius:50%;background:#FF8A00;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 32rpx rgba(255,138,0,0.4);margin-bottom:16rpx;}
.center-add-icon{font-size:56rpx;color:#FFF;font-weight:300;}
.center-add-text{font-size:30rpx;font-weight:600;}
.food-list-card{padding:0;overflow:hidden;}
.food-entry{border-bottom:2rpx solid #F5F0EA;}
.food-entry:last-child{border-bottom:none;}
.food-entry-row{display:flex;align-items:center;gap:16rpx;padding:20rpx 28rpx;}
.food-icon-wrap{width:80rpx;height:80rpx;border-radius:50%;background:#FFF7ED;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.06);}
.food-item-icon{font-size:42rpx;}
.food-item-img{width:80rpx;height:80rpx;border-radius:50%;}
.food-item-info{flex:1;min-width:0;}
.food-item-name{font-size:28rpx;font-weight:500;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.food-item-time{font-size:22rpx;color:#8E8E93;display:block;margin-top:4rpx;}
.food-item-cal{font-size:26rpx;font-weight:600;color:#FF6B35;flex-shrink:0;}
.food-item-del{width:44rpx;height:44rpx;display:flex;align-items:center;justify-content:center;font-size:32rpx;color:#C7C7CC;}
.show-more{text-align:center;padding:20rpx 0;border-top:2rpx solid #F5F0EA;}
.show-more-text{font-size:24rpx;color:#FF8A00;}
.empty-card{padding:60rpx 28rpx;text-align:center;}
.empty-text{font-size:26rpx;color:#FF8A00;}
.input-card{background:#FFF;border-radius:28rpx;padding:32rpx;margin-bottom:20rpx;box-shadow:0 4rpx 24rpx rgba(0,0,0,0.05);}
.card-title{font-size:32rpx;font-weight:600;display:block;margin-bottom:24rpx;}
.textarea-wrap{border:2rpx solid #F0ECE6;border-radius:20rpx;padding:24rpx;margin-bottom:24rpx;min-height:160rpx;position:relative;}
.food-textarea{width:100%;min-height:160rpx;font-size:28rpx;line-height:1.6;box-sizing:border-box;}
.clear-btn{position:absolute;top:12rpx;right:12rpx;width:44rpx;height:44rpx;border-radius:50%;background:#E0E0E0;color:#FFF;font-size:28rpx;display:flex;align-items:center;justify-content:center;z-index:10;}
.textarea-placeholder{font-size:28rpx;color:#BCBCBC;line-height:1.6;}
.action-row{display:flex;align-items:center;gap:20rpx;margin-bottom:24rpx;}
.mic-btn{width:72rpx;height:72rpx;border-radius:50%;border:3rpx solid #FF8A00;display:flex;align-items:center;justify-content:center;background:#FFF;flex-shrink:0;transition:all 0.3s;}
.mic-recording{background:#FF8A00;border-color:#FF6B35;box-shadow:0 0 16rpx rgba(255,138,0,0.5);}
.mic-wave{display:flex;align-items:center;gap:4rpx;height:36rpx;}
.mw-bar{width:5rpx;border-radius:3rpx;background:#FFF;animation:mw-bounce 0.7s ease-in-out infinite;}
.mw-bar:nth-child(1){height:10rpx;animation-delay:0s;}
.mw-bar:nth-child(2){height:20rpx;animation-delay:0.1s;}
.mw-bar:nth-child(3){height:28rpx;animation-delay:0.2s;}
.mw-bar:nth-child(4){height:20rpx;animation-delay:0.3s;}
.mw-bar:nth-child(5){height:10rpx;animation-delay:0.4s;}
@keyframes mw-bounce{0%,100%{transform:scaleY(0.4);}50%{transform:scaleY(1);}}
.rec-hint{font-size:22rpx;color:#FF8A00;font-weight:500;white-space:nowrap;}
.i-mic{display:flex;flex-direction:column;align-items:center;}
.i-mic-head{width:14rpx;height:18rpx;border:3rpx solid #FF8A00;border-radius:8rpx;}
.i-mic-body{width:22rpx;height:8rpx;border:3rpx solid #FF8A00;border-top:none;border-radius:0 0 11rpx 11rpx;margin-top:1rpx;}
.i-mic-base{width:3rpx;height:6rpx;background:#FF8A00;margin-top:1rpx;}
.act-btn{width:56rpx;height:56rpx;border-radius:50%;border:3rpx solid #FF8A00;display:flex;align-items:center;justify-content:center;background:#FFF;}
.i-cam{display:flex;flex-direction:column;align-items:center;}
.i-cam-top{width:12rpx;height:5rpx;border:2rpx solid #FF8A00;border-bottom:none;border-radius:3rpx 3rpx 0 0;margin-bottom:-1rpx;}
.i-cam-body{width:28rpx;height:18rpx;border:2rpx solid #FF8A00;border-radius:4rpx;display:flex;align-items:center;justify-content:center;}
.i-cam-lens{width:10rpx;height:10rpx;border:2rpx solid #FF8A00;border-radius:50%;}
.i-alb{display:flex;align-items:center;justify-content:center;}
.i-alb-frame{width:28rpx;height:22rpx;border:2rpx solid #FF8A00;border-radius:4rpx;position:relative;overflow:hidden;}
.i-alb-mt{position:absolute;bottom:-2rpx;right:3rpx;width:0;height:0;border-left:8rpx solid transparent;border-right:8rpx solid transparent;border-bottom:10rpx solid #FF8A00;}
.i-alb-sun{position:absolute;top:3rpx;left:4rpx;width:6rpx;height:6rpx;background:#FF8A00;border-radius:50%;}
.ai-btn{width:100%;height:88rpx;border-radius:44rpx;background:linear-gradient(135deg,#FFB366,#FF8A00);display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(255,138,0,0.3);}
.ai-btn-text{color:#FFF;font-size:30rpx;font-weight:600;}
.photo-grid{display:flex;flex-wrap:wrap;gap:16rpx;margin-bottom:20rpx;}
.photo-row{position:relative;display:inline-block;}
.photo-thumb{width:160rpx;height:160rpx;border-radius:16rpx;display:block;}
.photo-remove{position:absolute;top:-12rpx;right:-12rpx;width:40rpx;height:40rpx;border-radius:50%;background:rgba(0,0,0,0.5);color:#FFF;font-size:28rpx;display:flex;align-items:center;justify-content:center;}
.ai-loading-bar{display:flex;align-items:center;justify-content:center;gap:12rpx;padding:20rpx 0;}
.ai-spin{width:36rpx;height:36rpx;border-radius:50%;border:4rpx solid #FFD4A8;border-top-color:#FF8A00;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.ai-lt{font-size:26rpx;color:#FF8A00;}
