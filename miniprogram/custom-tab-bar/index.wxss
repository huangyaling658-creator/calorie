.tab-bar{display:flex;position:fixed;bottom:0;left:0;right:0;height:110rpx;background:rgba(255,255,255,0.96);backdrop-filter:blur(20px);border-top:1rpx solid #F5F0EA;padding-bottom:env(safe-area-inset-bottom);z-index:998;}
.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8rpx 0;color:#8E8E93;transition:color 0.2s;}
.tab-item.active{color:#FF8A00;} .tab-icon{font-size:40rpx;margin-bottom:4rpx;} .tab-label{font-size:20rpx;font-weight:500;}
